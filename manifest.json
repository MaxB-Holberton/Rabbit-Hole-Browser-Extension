{
  "name": "Rabbit Hole",
  "description": "Collate, organise and share your browser history!",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/rbe_logo_390.png"
  },
  "background": {"service_worker": "gethistory.js"},
  "permissions": [
  "storage",
  "history"
  ]
}
