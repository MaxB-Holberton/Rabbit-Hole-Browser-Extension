{
  "name": "rabbit-hole-browser-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:index": "esbuild src/index.jsx --bundle --format=iife --outfile=dist/homepage.js --jsx=automatic",
    "build:popup": "esbuild src/popup.js --bundle --format=iife --outfile=dist/popup.js",
    "build:history": "esbuild src/history.js --bundle --format=iife --outfile=dist/history.js",
    "build": "npm run build:index && npm run build:popup && npm run build:history"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "esbuild": "^0.23.1"
  }
}
